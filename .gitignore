# Monorepo root .gitignore
# Covers:
# - ekushey_coding (Flutter frontend)
# - dart-backend-ekushey_coding (Dart backend)

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IDE
*.iml
*.ipr
*.iws
.idea/

# VS Code (uncomment if you do not want to commit it)
#.vscode/

# Flutter/Dart/Pub caches (all projects)
**/doc/api/
**/ios/Flutter/.last_build_id
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/

# Build and coverage outputs
ekushey_coding/build/
ekushey_coding/coverage/
dart-backend-ekushey_coding/build/

# Symbolication / obfuscation
app.*.symbols
app.*.map.json

# Flutter Android build artifacts
ekushey_coding/android/app/debug
ekushey_coding/android/app/profile
ekushey_coding/android/app/release

# Backend local environment file
dart-backend-ekushey_coding/.env
